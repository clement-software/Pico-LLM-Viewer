CompileFlags:
  Remove:
    - -mcpu=*
    - -mfpu=*
    - -mfloat-abi=*
    - -march=*
    - -mthumb
    - -mthumb-interwork
    - --specs=*
    - -fno-exceptions
    - -fno-rtti
  Add:
    - -std=c++17
    - -Isrc
    - -Wno-invalid-constexpr
    - -I/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include/c++/15.2.1
    - -I/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include/c++/15.2.1/arm-none-eabi
    - -I/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/arm-none-eabi/include
    - -I/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/lib/gcc/arm-none-eabi/15.2.1/include
    - -I/Applications/ArmGNUToolchain/15.2.rel1/arm-none-eabi/lib/gcc/arm-none-eabi/15.2.1/include-fixed
---
If:
  PathMatch: lib/.*
Diagnostics:
  Suppress: "*"
